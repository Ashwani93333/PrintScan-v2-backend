# PrintEase Backend — Required Environment Variables
# Copy this file to .env and fill in production values.

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL connection
DATABASE_URL=jdbc:postgresql://your-db-host:5432/printease_db
DATABASE_USERNAME=printease_user
DATABASE_PASSWORD=change-me-strong-password

# JWT signing secret (min 32 characters, random)
JWT_SECRET=change-me-to-a-random-64-char-hex-string-for-production-use

# CORS — comma-separated allowed origins
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# File storage root path (mount a persistent volume here in container deployments)
STORAGE_LOCATION=/var/printease/uploads

# Server port
PORT=8080

# Optional: set to 'true' on FIRST boot only to seed the initial Super Admin user
SEED_SUPER_ADMIN=false
